# Copy this file to .env and fill in your values from the AWS console.
# Never commit .env to git.

# AWS Region (must match where you created the Cognito user pool)
VITE_AWS_REGION=ap-southeast-1

# Cognito — from: Cognito → User pools → your pool → App clients
VITE_USER_POOL_ID=ap-southeast-1_XXXXXXXXX
VITE_USER_POOL_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# API Gateway — from: API Gateway → your API → Stages → Invoke URL
# No trailing slash
VITE_API_URL=https://XXXXXXXXXX.execute-api.ap-southeast-1.amazonaws.com
